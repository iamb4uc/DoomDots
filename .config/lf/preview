#!/usr/bin/env bash
set -u

file="$1"
w="${2:-80}"
h="${3:-40}"
x="${4:-0}"
y="${5:-0}"
mode="${6:-preview}"

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/lf"
mkdir -p "$cache_dir"

id="lf-preview"
text_lines="${LF_PREVIEW_TEXT_LINES:-220}"
fifo_timeout="${LF_PREVIEW_FIFO_TIMEOUT:-0.5}"
thumb_timeout="${LF_PREVIEW_THUMB_TIMEOUT:-1.5}"
video_timeout="${LF_PREVIEW_VIDEO_TIMEOUT:-1.5}"
meta_timeout="${LF_PREVIEW_META_TIMEOUT:-1.5}"
list_timeout="${LF_PREVIEW_LIST_TIMEOUT:-1.5}"
thumb_px="${LF_PREVIEW_THUMB_PX:-900}"

have() { command -v "$1" >/dev/null 2>&1; }

json_escape() {
    sed 's/\\/\\\\/g; s/"/\\"/g' <<EOF
$1
EOF
}

realpath_f() {
    readlink -f -- "$1" 2>/dev/null || printf '%s' "$1"
}

hash_file() {
    local target
    target="$(realpath_f "$1")"
    stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$target" 2>/dev/null |
        sha256sum | awk '{print $1}'
}

batcmd() {
    if have batcat; then
        batcat "$@"
    elif have bat; then
        bat "$@"
    else
        cat "$@"
    fi
}

preview_text() {
    if have batcat || have bat; then
        batcmd --style=plain --color=always --paging=never --line-range=":${text_lines}" -- "$1"
    else
        sed -n "1,${text_lines}p" -- "$1"
    fi
}

run_timeout() {
    local secs="$1"
    shift
    timeout "$secs" "$@" 2>/dev/null
}

draw_with_ueberzug() {
    local img="$1" path identifier payload
    [ -n "${FIFO_UEBERZUG-}" ] || return 1
    [ -p "$FIFO_UEBERZUG" ] || return 1
    [ -n "${DISPLAY-}" ] || return 1
    [ -z "${WAYLAND_DISPLAY-}" ] || return 1

    path="$(json_escape "$img")"
    identifier="$(json_escape "$id")"
    payload="$(printf \
        '{"action":"add","identifier":"%s","path":"%s","x":%s,"y":%s,"width":%s,"height":%s,"scaler":"contain"}' \
        "$identifier" "$path" "$x" "$y" "$w" "$h")"

    timeout "$fifo_timeout" sh -c 'printf "%s\n" "$1" >"$2"' sh "$payload" "$FIFO_UEBERZUG" 2>/dev/null
}

make_video_thumb() {
    local src="$1" dst="$2" tmp

    [ -s "$dst" ] && return 0
    have ffmpegthumbnailer || return 1

    tmp="${dst%.*}.$$.${dst##*.}"
    timeout "$video_timeout" ffmpegthumbnailer \
        -i "$src" \
        -o "$tmp" \
        -s "$thumb_px" \
        -t 8% \
        -q 5 >/dev/null 2>&1 &&
        [ -s "$tmp" ] &&
        mv -f "$tmp" "$dst"
    rm -f "$tmp"

    [ -s "$dst" ]
}

draw_image() {
    local img="$1"

    draw_with_ueberzug "$img" && exit 1
    if have chafa; then
        run_timeout "$meta_timeout" chafa --size="${w}x${h}" -- "$img" && exit 0
    elif have viu; then
        run_timeout "$meta_timeout" viu -w "$w" -h "$h" -- "$img" && exit 0
    fi

    return 1
}

mime="$(file --dereference --brief --mime-type -- "$file" 2>/dev/null || printf 'application/octet-stream')"
hash="$(hash_file "$file")"
thumb_base="$cache_dir/thumb.$hash"
thumb_png="${thumb_base}.png"
thumb_jpg="${thumb_base}.jpg"
text_cache="${thumb_base}.txt"

case "$mime" in
inode/x-empty)
    printf '[empty file]\n'
    ;;

text/* | application/xml | application/x-xml | application/x-sh | application/x-shellscript | application/javascript | application/x-javascript | application/x-yaml | application/yaml)
    preview_text "$file"
    ;;

text/html)
    if have lynx; then
        lynx -width="$w" -display_charset=utf-8 -dump "$file"
    else
        preview_text "$file"
    fi
    ;;

application/json | application/x-ndjson)
    if have jq; then
        jq -C . -- "$file" 2>/dev/null || preview_text "$file"
    else
        preview_text "$file"
    fi
    ;;

image/svg+xml)
    if have magick; then
        [ -s "$thumb_png" ] || run_timeout "$thumb_timeout" magick "$file" -strip -thumbnail "${thumb_px}x${thumb_px}>" "$thumb_png" >/dev/null
        [ -f "$thumb_png" ] && draw_image "$thumb_png"
    fi
    preview_text "$file"
    ;;

image/x-xcf)
    if have magick; then
        [ -s "$thumb_jpg" ] || run_timeout "$thumb_timeout" magick "$file[0]" -strip -thumbnail "${thumb_px}x${thumb_px}>" "$thumb_jpg" >/dev/null
        [ -f "$thumb_jpg" ] && draw_image "$thumb_jpg"
    fi
    file --dereference --brief -- "$file"
    ;;

image/*)
    draw_image "$file" || file --dereference --brief -- "$file"
    ;;

video/*)
    if make_video_thumb "$file" "$thumb_jpg"; then
        draw_image "$thumb_jpg"
    else
        file --dereference --brief -- "$file"
    fi
    ;;

audio/*)
    if have mediainfo; then
        run_timeout "$meta_timeout" mediainfo "$file"
    elif have exiftool; then
        run_timeout "$meta_timeout" exiftool "$file"
    else
        file -- "$file"
    fi
    ;;

application/pdf)
    if have pdftotext; then
        pdftotext -f 1 -l 5 -nopgbrk -q "$file" - >"$text_cache" 2>/dev/null || true
        if grep -q '[[:alnum:]]' "$text_cache" 2>/dev/null; then
            preview_text "$text_cache"
            exit 0
        fi
    fi

    if have pdftoppm; then
        [ -s "$thumb_png" ] || run_timeout "$thumb_timeout" pdftoppm -png -f 1 -singlefile -scale-to "$thumb_px" "$file" "$thumb_base" >/dev/null
        [ -f "$thumb_png" ] && draw_image "$thumb_png"
    fi

    if have pdfinfo; then
        run_timeout "$meta_timeout" pdfinfo "$file"
    else
        file -- "$file"
    fi
    ;;

application/epub+zip | application/x-mobipocket-ebook)
    if have gnome-epub-thumbnailer; then
        [ -s "$thumb_jpg" ] || run_timeout "$thumb_timeout" gnome-epub-thumbnailer "$file" "$thumb_jpg" >/dev/null
        [ -f "$thumb_jpg" ] && draw_image "$thumb_jpg"
    fi
    if have pandoc; then
        run_timeout "$meta_timeout" pandoc -t plain "$file" | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/zip | application/x-7z-compressed | application/x-rar | application/x-rar-compressed | application/x-tar | application/gzip | application/x-bzip2 | application/x-xz | application/zstd)
    if have 7z; then
        run_timeout "$list_timeout" 7z l -- "$file" | sed -n '1,250p'
    elif have bsdtar; then
        run_timeout "$list_timeout" bsdtar -tf "$file" | sed -n '1,250p'
    elif have unzip; then
        run_timeout "$list_timeout" unzip -l "$file" | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.openxmlformats-officedocument.wordprocessingml.document)
    if have docx2txt; then
        run_timeout "$meta_timeout" docx2txt "$file" - | sed -n '1,250p'
    elif have pandoc; then
        run_timeout "$meta_timeout" pandoc -t plain "$file" | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.oasis.opendocument.text)
    if have odt2txt; then
        run_timeout "$meta_timeout" odt2txt "$file" | sed -n '1,250p'
    elif have pandoc; then
        run_timeout "$meta_timeout" pandoc -t plain "$file" | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.openxmlformats-officedocument.spreadsheetml.sheet)
    if have xlsx2csv; then
        run_timeout "$meta_timeout" xlsx2csv "$file" | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.ms-excel)
    if have xls2csv; then
        run_timeout "$meta_timeout" xls2csv "$file" | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.openxmlformats-officedocument.presentationml.presentation)
    if have pandoc; then
        run_timeout "$meta_timeout" pandoc -t plain "$file" | sed -n '1,250p'
    else
        run_timeout "$meta_timeout" unzip -p "$file" 'ppt/slides/slide*.xml' |
            sed 's/<[^>]*>/ /g' |
            tr -s ' ' |
            sed -n '1,250p'
    fi
    ;;

*)
    file --dereference --brief -- "$file"
    printf '\n'
    if have exiftool; then
        run_timeout "$meta_timeout" exiftool "$file" | sed -n '1,80p'
    fi
    ;;
esac

exit 0
