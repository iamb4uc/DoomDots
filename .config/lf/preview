#!/usr/bin/env bash
set -u

file="$1"
w="${2:-80}"
h="${3:-40}"
x="${4:-0}"
y="${5:-0}"
mode="${6:-preview}"

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/lf"
mkdir -p "$cache_dir"

id="lf-preview"
text_lines="${LF_PREVIEW_TEXT_LINES:-220}"
fifo_timeout="${LF_PREVIEW_FIFO_TIMEOUT:-0.08}"
thumb_timeout="${LF_PREVIEW_THUMB_TIMEOUT:-1.5}"
video_timeout="${LF_PREVIEW_VIDEO_TIMEOUT:-1.5}"
thumb_px="${LF_PREVIEW_THUMB_PX:-900}"
chafa_colors="${LF_PREVIEW_CHAFA_COLORS:-256}"
chafa_threads="${LF_PREVIEW_CHAFA_THREADS:-1}"
chafa_work="${LF_PREVIEW_CHAFA_WORK:-1}"

have() { command -v "$1" >/dev/null 2>&1; }

realpath_f() {
    readlink -f -- "$1" 2>/dev/null || printf '%s' "$1"
}

hash_file() {
    local target
    target="$(realpath_f "$1")"
    stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$target" 2>/dev/null |
        sha256sum | awk '{print $1}'
}

batcmd() {
    if have batcat; then
        batcat "$@"
    elif have bat; then
        bat "$@"
    else
        cat "$@"
    fi
}

preview_text() {
    if have batcat || have bat; then
        batcmd --style=plain --color=always --paging=never --line-range=":${text_lines}" -- "$1"
    else
        sed -n "1,${text_lines}p" -- "$1"
    fi
}

draw_with_kitty() {
    local img="$1"
    kitten icat \
        --stdin=no \
        --transfer-mode=memory \
        --place "${w}x${h}@${x}x${y}" \
        -- "$img" </dev/null >/dev/tty 2>/dev/null
}

draw_with_ueberzug() {
    local img="$1" payload
    [ -n "${FIFO_UEBERZUG-}" ] || return 1
    [ -p "$FIFO_UEBERZUG" ] || return 1
    [ -n "${DISPLAY-}" ] || return 1
    [ -z "${WAYLAND_DISPLAY-}" ] || return 1
    have jq || return 1

    payload="$(jq -cn \
        --arg path "$img" \
        --arg identifier "$id" \
        --argjson x "$x" \
        --argjson y "$y" \
        --argjson width "$w" \
        --argjson height "$h" \
        '{
          action: "add",
          identifier: $identifier,
          path: $path,
          x: $x,
          y: $y,
          width: $width,
          height: $height,
          scaler: "contain"
        }')"

    timeout "$fifo_timeout" sh -c 'printf "%s\n" "$1" >"$2"' sh "$payload" "$FIFO_UEBERZUG" 2>/dev/null
}

draw_with_ueberzugpp() {
    local img="$1"
    [ -n "${LF_UEBERZUG_FIFO-}" ] || return 1
    [ -p "${LF_UEBERZUG_FIFO}" ] || return 1
    have jq || return 1

    timeout "$fifo_timeout" jq -cn \
        --arg path "$img" \
        --arg identifier "$id" \
        --argjson x "$x" \
        --argjson y "$y" \
        --argjson mw "$w" \
        --argjson mh "$h" \
        '{
          action: "add",
          identifier: $identifier,
          path: $path,
          x: $x,
          y: $y,
          max_width: $mw,
          max_height: $mh,
          scaler: "fit_contain"
        }' >"$LF_UEBERZUG_FIFO" 2>/dev/null
}

draw_with_chafa() {
    local img="$1"
    chafa \
        --probe off \
        --format symbols \
        --symbols block+half \
        --colors "$chafa_colors" \
        --color-space rgb \
        --dither none \
        --preprocess off \
        --work "$chafa_work" \
        --threads "$chafa_threads" \
        --passthrough none \
        --polite on \
        --animate off \
        --size "${w}x${h}" \
        -- "$img"
}

make_video_thumb() {
    local src="$1" dst="$2" tmp

    [ -s "$dst" ] && return 0
    have ffmpegthumbnailer || return 1

    tmp="${dst%.*}.$$.${dst##*.}"
    timeout "$video_timeout" ffmpegthumbnailer \
        -i "$src" \
        -o "$tmp" \
        -s "$thumb_px" \
        -t 8% \
        -q 5 >/dev/null 2>&1 &&
        [ -s "$tmp" ] &&
        mv -f "$tmp" "$dst"
    rm -f "$tmp"

    [ -s "$dst" ]
}

draw_image() {
    local img="$1"

    if [ -n "${FIFO_UEBERZUG-}" ]; then
        draw_with_ueberzug "$img" && exit 1
    fi

    if [ -n "${KITTY_WINDOW_ID-}" ] && have kitten; then
        draw_with_kitty "$img" && exit 1
    fi

    if have ueberzugpp && [ -n "${LF_UEBERZUG_FIFO-}" ]; then
        draw_with_ueberzugpp "$img" && exit 1
    fi

    if have chafa; then
        draw_with_chafa "$img" || true
        exit 0
    fi

    file --dereference --brief -- "$img"
    exit 0
}

mime="$(file --dereference --brief --mime-type -- "$file" 2>/dev/null || printf 'application/octet-stream')"
hash="$(hash_file "$file")"
thumb_base="$cache_dir/thumb.$hash"
thumb_png="${thumb_base}.png"
thumb_jpg="${thumb_base}.jpg"
text_cache="${thumb_base}.txt"

case "$mime" in
inode/x-empty)
    printf '[empty file]\n'
    ;;

text/* | application/xml | application/x-xml | application/x-sh | application/x-shellscript | application/javascript | application/x-javascript | application/x-yaml | application/yaml)
    preview_text "$file"
    ;;

text/html)
    if have lynx; then
        lynx -width="$w" -display_charset=utf-8 -dump "$file"
    else
        preview_text "$file"
    fi
    ;;

application/json | application/x-ndjson)
    if have jq; then
        jq -C . -- "$file" 2>/dev/null || preview_text "$file"
    else
        preview_text "$file"
    fi
    ;;

image/svg+xml)
    if have magick; then
        [ -s "$thumb_png" ] || timeout "$thumb_timeout" magick "$file" -strip -thumbnail "${thumb_px}x${thumb_px}>" "$thumb_png" >/dev/null 2>&1
        [ -f "$thumb_png" ] && draw_image "$thumb_png"
    fi
    preview_text "$file"
    ;;

image/x-xcf)
    if have magick; then
        [ -s "$thumb_jpg" ] || timeout "$thumb_timeout" magick "$file[0]" -strip -thumbnail "${thumb_px}x${thumb_px}>" "$thumb_jpg" >/dev/null 2>&1
        [ -f "$thumb_jpg" ] && draw_image "$thumb_jpg"
    fi
    file --dereference --brief -- "$file"
    ;;

image/*)
    draw_image "$file"
    ;;

video/*)
    if make_video_thumb "$file" "$thumb_jpg"; then
        draw_image "$thumb_jpg"
    else
        file --dereference --brief -- "$file"
    fi
    ;;

audio/*)
    if have mediainfo; then
        mediainfo "$file"
    elif have exiftool; then
        exiftool "$file"
    else
        file -- "$file"
    fi
    ;;

application/pdf)
    if have pdftotext; then
        pdftotext -f 1 -l 5 -nopgbrk -q "$file" - >"$text_cache" 2>/dev/null || true
        if grep -q '[[:alnum:]]' "$text_cache" 2>/dev/null; then
            preview_text "$text_cache"
            exit 0
        fi
    fi

    if have pdftoppm; then
        [ -s "$thumb_png" ] || timeout "$thumb_timeout" pdftoppm -png -f 1 -singlefile -scale-to "$thumb_px" "$file" "$thumb_base" >/dev/null 2>&1
        [ -f "$thumb_png" ] && draw_image "$thumb_png"
    fi

    if have pdfinfo; then
        pdfinfo "$file"
    else
        file -- "$file"
    fi
    ;;

application/epub+zip | application/x-mobipocket-ebook)
    if have gnome-epub-thumbnailer; then
        [ -s "$thumb_jpg" ] || timeout "$thumb_timeout" gnome-epub-thumbnailer "$file" "$thumb_jpg" >/dev/null 2>&1
        [ -f "$thumb_jpg" ] && draw_image "$thumb_jpg"
    fi
    if have pandoc; then
        pandoc -t plain "$file" 2>/dev/null | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/zip | application/x-7z-compressed | application/x-rar | application/x-rar-compressed | application/x-tar | application/gzip | application/x-bzip2 | application/x-xz | application/zstd)
    if have 7z; then
        7z l -- "$file"
    elif have bsdtar; then
        bsdtar -tf "$file"
    elif have unzip; then
        unzip -l "$file"
    else
        file -- "$file"
    fi
    ;;

application/vnd.openxmlformats-officedocument.wordprocessingml.document)
    if have docx2txt; then
        docx2txt "$file" - 2>/dev/null | sed -n '1,250p'
    elif have pandoc; then
        pandoc -t plain "$file" 2>/dev/null | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.oasis.opendocument.text)
    if have odt2txt; then
        odt2txt "$file" 2>/dev/null | sed -n '1,250p'
    elif have pandoc; then
        pandoc -t plain "$file" 2>/dev/null | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.openxmlformats-officedocument.spreadsheetml.sheet)
    if have xlsx2csv; then
        xlsx2csv "$file" 2>/dev/null | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.ms-excel)
    if have xls2csv; then
        xls2csv "$file" 2>/dev/null | sed -n '1,250p'
    else
        file -- "$file"
    fi
    ;;

application/vnd.openxmlformats-officedocument.presentationml.presentation)
    if have pandoc; then
        pandoc -t plain "$file" 2>/dev/null | sed -n '1,250p'
    else
        unzip -p "$file" 'ppt/slides/slide*.xml' 2>/dev/null |
            sed 's/<[^>]*>/ /g' |
            tr -s ' ' |
            sed -n '1,250p'
    fi
    ;;

*)
    file --dereference --brief -- "$file"
    printf '\n'
    if have exiftool; then
        exiftool "$file" 2>/dev/null | sed -n '1,80p'
    fi
    ;;
esac

exit 0
