#!/bin/sh
set -eu

if [ "$(id -u)" -ne 0 ]; then
  echo "This script must be run with sudo or as root."
  exit 1
fi

if ! command -v xbps-install >/dev/null 2>&1 || ! command -v xbps-remove >/dev/null 2>&1; then
  echo "This script is for Void Linux systems with xbps installed."
  exit 1
fi

xbps-install -S symlinks chkstat || true

xbps-install -Suv
xbps-remove -Oo
xbps-remove -O

if command -v vkpurge >/dev/null 2>&1; then
  vkpurge rm all || true
fi

if command -v symlinks >/dev/null 2>&1; then
  symlinks -r /etc /usr /var 2>/dev/null || true
fi

xbps-remove -R symlinks || true

find /var/log -type f -name "*.log.*" -delete

if command -v journalctl >/dev/null 2>&1; then
  journalctl --vacuum-time=7d || true
fi

xbps-pkgdb -m repolock
xbps-pkgdb -a
xbps-reconfigure -a
df -h

printf "\nSystem maintenance and best practice checks completed successfully.\n"
